%% FTI skeleton for an awesome-ml-systems repo.
%% Paste into a ```mermaid block in the README. Rename nodes per system,
%% keep the shape: source -> Feature -> Training -> Inference.
flowchart LR
    src([data source]):::ext

    subgraph FE[Feature]
        direction TB
        ingest[ingest / collect] --> fp[feature pipeline] --> fg[(Feature Group)]:::hops
    end
    subgraph TR[Training]
        direction TB
        fv[Feature View] --> train[train / autoresearch] --> reg[(Model Registry)]:::hops
    end
    subgraph INF[Inference]
        direction TB
        ep[endpoint]:::hops --> app[app]
    end

    src --> ingest
    fg --> fv
    reg --> ep
    user([user input]):::ext --> app --> ep

    classDef hops fill:#10b98118,stroke:#34d399,stroke-width:1px;
    classDef ext fill:none,stroke:#9ca3af,stroke-dasharray:4 3;
